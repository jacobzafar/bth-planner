# Lovable Cloud / Supabase configuration
# These values are auto-populated by Lovable Cloud when running on Lovable.
# For local development, copy this file to `.env` and fill in your values.

# Public Supabase URL (e.g. https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=
SUPABASE_URL=

# Supabase publishable (anon) key — safe to expose to the browser
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Supabase project ref (the subdomain part of your project URL)
VITE_SUPABASE_PROJECT_ID=
